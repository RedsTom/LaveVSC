{
	"name": "lave-language-support",
	"description": "Lave Language Support",
	"author": "RedsTom",
	"license": "MIT",
	"version": "1.0.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/RedsTom/LaveVSC"
	},
	"publisher": "redstom",
	"categories": [],
	"keywords": [
		"multi-root ready"
	],
	"engines": {
		"vscode": "^1.100.0"
	},
	"activationEvents": [
		"onLanguage:lave"
	],
	"main": "./out/extension",
	"contributes": {
		"languages": [
			{
				"id": "lave",
				"aliases": [
					"Lave",
					"lave"
				],
				"extensions": [
					".lave"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "lave",
				"scopeName": "source.lave",
				"path": "./syntaxes/lave.tmLanguage.json"
			}
		],
		"configuration": {
			"type": "object",
			"title": "Lave Language Support",
			"properties": {
				"lave.maxNumberOfProblems": {
					"scope": "resource",
					"type": "number",
					"default": 100,
					"description": "Controls the maximum number of problems produced by the server."
				},
				"lave.trace.server": {
					"scope": "window",
					"type": "string",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"default": "off",
					"description": "Traces the communication between VS Code and the language server."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "pnpm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -w -p ./",
		"lint": "eslint src --ext ts"
	},
	"devDependencies": {
		"@types/vscode": "^1.100.0",
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/mocha": "^10.0.6",
		"@types/node": "^22",
		"eslint": "^9.13.0",
		"mocha": "^10.3.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0",
		"vscode-languageclient": "^9.0.1"
	}
}
