{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Lave",
	"scopeName": "source.lave",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#entities"
		},
		{
			"include": "#punctuation"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.lave",
					"match": "//.*"
				},
				{
					"name": "comment.block.lave",
					"begin": "/\\*",
					"end": "\\*/",
					"patterns": [
						{
							"include": "#comments"
						}
					]
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.lave",
					"match": "\\b(si|alors|sinon|fin|tant|que|faire|pour|renvoyer|fait|faire)\\b"
				},
				{
					"name": "keyword.declaration.lave",
					"match": "\\b(algo|struct|est)\\b"
				},
				{
					"name": "keyword.operator.lave",
					"match": "\\b(ou|et|non|dans|à)\\b"
				},
				{
					"name": "constant.language.lave",
					"match": "\\b(vrai|faux)\\b"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.assignment.lave",
					"match": ":="
				},
				{
					"name": "keyword.operator.arrow.lave",
					"match": "->"
				},
				{
					"name": "keyword.operator.comparison.lave",
					"match": "=|!=|<=?|>=?"
				},
				{
					"name": "keyword.operator.arithmetic.lave",
					"match": "\\+|-|\\*|/|//|%"
				},
				{
					"name": "keyword.operator.bitwise.lave",
					"match": "\\||\\^|&|<<|>>"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.lave",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.lave",
					"match": "\\\\."
				}
			]
		},
		"numbers": {
			"name": "constant.numeric.lave",
			"match": "\\b\\d+(\\.\\d+)?\\b"
		},
		"entities": {
			"patterns": [
				{
					"name": "entity.name.function.lave",
					"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
				},
				{
					"name": "entity.name.type.struct.lave",
					"begin": "\\b(struct)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
					"beginCaptures": {
						"1": { "name": "keyword.declaration.lave" },
						"2": { "name": "entity.name.type.struct.lave" }
					},
					"end": "(?=est)",
					"patterns": []
				},
				{
					"name": "entity.name.function.declaration.lave",
					"begin": "\\b(algo)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
					"beginCaptures": {
						"1": { "name": "keyword.declaration.lave" },
						"2": { "name": "entity.name.function.lave" }
					},
					"end": "(?=->)",
					"patterns": [{ "include": "#punctuation" }, { "include": "#types" }]
				},
				{
					"name": "variable.parameter.lave",
					"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*:)"
				}
			]
		},
		"types": {
			"name": "entity.name.type.lave",
			"match": "\\b([A-Z][a-zA-Z0-9_]*|entier|chaine|booleen|reel)\\b"
		},
		"punctuation": {
			"patterns": [
				{
					"name": "punctuation.separator.lave",
					"match": ","
				},
				{
					"name": "punctuation.accessor.lave",
					"match": "\\."
				},
				{
					"name": "punctuation.definition.type.lave",
					"match": ":"
				},
				{
					"name": "punctuation.section.parens.begin.lave",
					"match": "\\("
				},
				{
					"name": "punctuation.section.parens.end.lave",
					"match": "\\)"
				},
				{
					"name": "punctuation.section.brackets.begin.lave",
					"match": "\\["
				},
				{
					"name": "punctuation.section.brackets.end.lave",
					"match": "\\]"
				}
			]
		}
	}
}
